// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                    String         @id @default(uuid())
  username              String         @unique
  avatar                String
  bio                   String?
  points                Int            @default(0)
  hasAgreedToDisclaimer Boolean        @default(false)
  isAdmin               Boolean        @default(false)
  videos                Video[]
  comments              Comment[]
  sentMessages          Message[]      @relation("SentMessages")
  receivedMessages      Message[]      @relation("ReceivedMessages")
  sentFriendRequests    FriendRequest[] @relation("SentFriendRequests")
  receivedFriendRequests FriendRequest[] @relation("ReceivedFriendRequests")
  friendshipsInitiated  Friendship[]   @relation("FriendshipA")
  friendshipsAccepted   Friendship[]   @relation("FriendshipB")
  lastVoteAt            DateTime?
  voteStreak            Int            @default(0)
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @default(now()) @updatedAt
}

model FriendRequest {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  status     String   @default("pending") // 'pending' | 'accepted' | 'rejected'
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt
  sender     User     @relation("SentFriendRequests", fields: [senderId], references: [id])
  receiver   User     @relation("ReceivedFriendRequests", fields: [receiverId], references: [id])

  @@unique([senderId, receiverId])
}

model Friendship {
  id         String   @id @default(cuid())
  userAId    String
  userBId    String
  createdAt  DateTime @default(now())
  userA      User     @relation("FriendshipA", fields: [userAId], references: [id])
  userB      User     @relation("FriendshipB", fields: [userBId], references: [id])

  @@unique([userAId, userBId])
}

model Video {
  id           String    @id @default(cuid())
  userId       String
  username     String
  title        String
  description  String
  videoUrl     String
  thumbnailUrl String
  trips        Int       @default(0)
  category     String?
  createdAt    DateTime  @default(now())
  user         User      @relation(fields: [userId], references: [id])
  comments     Comment[]
}

model Comment {
  id        String   @id @default(cuid())
  userId    String
  videoId   String
  username  String
  avatar    String
  text      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  video     Video    @relation(fields: [videoId], references: [id])
}

model Message {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  text       String
  createdAt  DateTime @default(now())
  sender     User     @relation("SentMessages", fields: [senderId], references: [id])
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id])
}

model SafetyReport {
  id        String   @id @default(cuid())
  timestamp DateTime @default(now())
  type      String   // 'AI_AUTO' or 'USER_MANUAL'
  category  String   // 'comment', 'bio', 'message', 'video_meta', 'video_content', 'user'
  content   String
  reason    String
  reporter  String?
}
