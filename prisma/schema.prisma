// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                    String         @id @default(uuid())
  username              String         @unique
  avatar                String
  bio                   String?
  points                Int            @default(0)
  hasAgreedToDisclaimer Boolean        @default(false)
  isAdmin               Boolean        @default(false)
  videos                Video[]
  comments              Comment[]
  sentMessages          Message[]      @relation("SentMessages")
  receivedMessages      Message[]      @relation("ReceivedMessages")
  sentFriendRequests    FriendRequest[] @relation("SentFriendRequests")
  receivedFriendRequests FriendRequest[] @relation("ReceivedFriendRequests")
  friendshipsInitiated  Friendship[]   @relation("FriendshipA")
  friendshipsAccepted   Friendship[]   @relation("FriendshipB")
  following             Follow[]       @relation("Following")
  followers             Follow[]       @relation("Followers")
  notifications         Notification[] @relation("NotifRecipient")
  reactions             Reaction[]
  lastVoteAt            DateTime?
  voteStreak            Int            @default(0)
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @default(now()) @updatedAt
}

model FriendRequest {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  status     String   @default("pending") // 'pending' | 'accepted' | 'rejected'
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt
  sender     User     @relation("SentFriendRequests", fields: [senderId], references: [id])
  receiver   User     @relation("ReceivedFriendRequests", fields: [receiverId], references: [id])

  @@unique([senderId, receiverId])
}

model Friendship {
  id         String   @id @default(cuid())
  userAId    String
  userBId    String
  createdAt  DateTime @default(now())
  userA      User     @relation("FriendshipA", fields: [userAId], references: [id])
  userB      User     @relation("FriendshipB", fields: [userBId], references: [id])

  @@unique([userAId, userBId])
}

model Video {
  id           String    @id @default(cuid())
  userId       String
  username     String
  title        String
  description  String
  videoUrl     String
  thumbnailUrl String
  trips        Int       @default(0)
  category     String?
  createdAt    DateTime  @default(now())
  user         User      @relation(fields: [userId], references: [id])
  comments     Comment[]
  reactions    Reaction[]
}

model Comment {
  id        String   @id @default(cuid())
  userId    String
  videoId   String
  username  String
  avatar    String
  text      String
  parentId  String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  video     Video    @relation(fields: [videoId], references: [id])
  parent    Comment? @relation("CommentReplies", fields: [parentId], references: [id])
  replies   Comment[] @relation("CommentReplies")
}

model Message {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  text       String
  createdAt  DateTime @default(now())
  sender     User     @relation("SentMessages", fields: [senderId], references: [id])
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id])
}

model SafetyReport {
  id        String   @id @default(cuid())
  timestamp DateTime @default(now())
  type      String   // 'AI_AUTO' or 'USER_MANUAL'
  category  String   // 'comment', 'bio', 'message', 'video_meta', 'video_content', 'user'
  content   String
  reason    String
  reporter  String?
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())
  follower    User     @relation("Following", fields: [followerId], references: [id])
  following   User     @relation("Followers", fields: [followingId], references: [id])

  @@unique([followerId, followingId])
}

model Reaction {
  id        String   @id @default(cuid())
  videoId   String
  userId    String
  type      String   // 'fire' | 'laugh' | 'skull' | 'heart' | 'eyes'
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  video     Video    @relation(fields: [videoId], references: [id])

  @@unique([videoId, userId, type])
}

model Notification {
  id         String   @id @default(cuid())
  recipientId String
  actorId    String?
  type       String   // 'friend_request' | 'friend_accepted' | 'message' | 'video_vote' | 'new_follow' | 'comment' | 'reaction'
  entityId   String?  // videoId / userId / messageId depending on type
  text       String
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())
  recipient  User     @relation("NotifRecipient", fields: [recipientId], references: [id])

  @@index([recipientId, read])
}
