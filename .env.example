# Supabase environment variables (server-side)
SUPABASE_URL=https://xyzcompany.supabase.co
SUPABASE_ANON_KEY=public-anon-key
SUPABASE_SERVICE_ROLE_KEY=service-role-key

# Supabase environment variables (frontend / Vite - must be prefixed with VITE_)
VITE_SUPABASE_URL=https://xyzcompany.supabase.co
VITE_SUPABASE_ANON_KEY=public-anon-key

# Backend database connection (used by Prisma / Express server)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.xyzcompany.supabase.co:5432/postgres

# Local dev: optional
SUPABASE_DB_HOST=localhost
SUPABASE_DB_PORT=5432
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=postgres
SUPABASE_DB_NAME=postgres
