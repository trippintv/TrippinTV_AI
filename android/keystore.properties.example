# Copy to android/keystore.properties (gitignored) and fill in your values.
# Generate a keystore once with:
# keytool -genkey -v -keystore trippintv-release.keystore -alias trippintv -keyalg RSA -keysize 2048 -validity 10000
STORE_FILE=trippintv-release.keystore
STORE_PASSWORD=change_me
KEY_ALIAS=trippintv
KEY_PASSWORD=change_me
